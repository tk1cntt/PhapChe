generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Note: SQLite doesn't support enums, using String fields instead
// Role values: customer, specialist, reviewer, coordinator, super_admin
// RequestStatus values: draft_intake, intake_submitted, triage, assigned, in_progress, pending_review, revision_required, approved, delivered, closed, cancelled
// AssignmentKind values: specialist, reviewer
// AuditTargetType values: user, workspace, membership, request, matter_type, intake_submission, assignment, document, review, vault_file, workflow_transition
// DocumentVersionStatus values: draft, submitted_for_review, final
// TemplateStatus values: draft, approved, published, deprecated
// ReviewStatus values: in_progress, approved, rejected
// ReviewDecision values: approve, reject
// AccountType values: staff, customer
// Staff roles: super_admin, coordinator, specialist, reviewer
// Customer roles: customer (access org workspace or individual)

model User {
  id                 String               @id @default(cuid())
  email              String               @unique
  name               String
  phone              String?
  title              String?
  timezone           String?              @default("Asia/Ho_Chi_Minh")
  locale             String?              @default("vi")
  avatarUrl          String?
  accountType        String               @default("customer")  // "staff" or "customer"
  lastActiveAt       DateTime?
  isActive           Boolean              @default(true)
  emailVerified      Boolean              @default(false)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  memberships        WorkspaceMembership[]
  createdRequests    LegalRequest[]       @relation("RequestCreator")
  specialistRequests LegalRequest[]       @relation("AssignedSpecialist")
  reviewerRequests   LegalRequest[]       @relation("AssignedReviewer")
  assignments        RequestAssignment[]  @relation("AssignmentUser")
  createdAssignments RequestAssignment[]  @relation("AssignmentCreator")
  reviews            Review[]
  workflowActions    WorkflowTransition[]
  auditEvents        AuditEvent[]
  vaultFiles         VaultFile[]
  routingCapabilities RoutingCapability[]
  accounts           Account[]
  sessions           Session[]
  preferences        UserPreferences?
  createdFiles       File[]             @relation("FileCreator")
  fileVersions       FileVersion[]      @relation("FileVersionCreator")
  partnerMembers     PartnerMember[]
  sentMessages       Message[]      @relation("MessageSender")
  receivedMessages   Message[]      @relation("MessageRecipient")
}

model UserPreferences {
  id            String   @id @default(cuid())
  userId        String   @unique
  emailOnReply  Boolean  @default(true)
  slaReminder   Boolean  @default(true)
  weeklySummary Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ===== MULTI-TENANT MODELS =====

model Tenant {
  id        String         @id @default(cuid())
  name      String
  type      String         @default("platform")  // "platform" or "customer"
  settings  String         @default("{}")       // JSON settings
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  organizations Organization[]

  @@map("tenants")
}

model Organization {
  id                 String   @id @default(cuid())
  tenantId           String
  name               String
  businessType       String?
  registrationNumber String?
  address            String?
  contactEmail       String?
  status             String   @default("active")  // active, inactive, pending
  isDefault          Boolean  @default(false)    // First org per tenant
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  workspaces Workspace[]
  engagements Engagement[]

  @@index([tenantId])
  @@index([status])
  @@map("organizations")
}

// ===== PARTNER MODELS =====

model Partner {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  type         String   @default("law_firm")  // law_firm, consultancy, individual
  contactEmail String?
  phone        String?
  address      String?
  status       String   @default("active")  // active, inactive, pending
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members      PartnerMember[]
  engagements  Engagement[]
  assignedRequests LegalRequest[] @relation("AssignedPartnerRelation")
  requestAssignments RequestAssignment[] @relation("AssignmentPartnerRelation")

  @@map("partners")
}

model PartnerMember {
  id        String   @id @default(cuid())
  partnerId String
  userId    String
  role      String   @default("member")  // admin, member
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partner   Partner  @relation(fields: [partnerId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([partnerId, userId])
  @@index([partnerId])
  @@index([userId])
  @@map("partner_members")
}

// ===== ENGAGEMENT MODELS =====

model ServiceType {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  engagements EngagementServiceScope[]

  @@map("service_types")
}

model Engagement {
  id             String   @id @default(cuid())
  partnerId     String
  organizationId String
  status        String   @default("active")  // active, inactive, pending
  startDate     DateTime?
  endDate       DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  partner       Partner         @relation(fields: [partnerId], references: [id])
  organization  Organization    @relation(fields: [organizationId], references: [id])
  serviceScopes EngagementServiceScope[]
  requests      LegalRequest[]
  requestAssignments RequestAssignment[]

  @@unique([partnerId, organizationId])
  @@index([partnerId])
  @@index([organizationId])
  @@map("engagements")
}

model EngagementServiceScope {
  id               String   @id @default(cuid())
  engagementId    String
  serviceTypeId   String
  permissionLevel String   @default("case_assigned")  // case_assigned, service_wide, full_access
  createdAt       DateTime @default(now())

  engagement   Engagement   @relation(fields: [engagementId], references: [id])
  serviceType  ServiceType @relation(fields: [serviceTypeId], references: [id])

  @@unique([engagementId, serviceTypeId])
  @@index([engagementId])
  @@index([serviceTypeId])
  @@map("engagement_service_scopes")
}

model Workspace {
  id               String                @id @default(cuid())
  name             String
  slug             String                @unique
  isActive         Boolean               @default(true)
  organizationId   String?              // FK to Organization
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  memberships      WorkspaceMembership[]
  requests         LegalRequest[]
  files            File[]
  matterTypes      MatterType[]
  routingCapabilities RoutingCapability[]
  documents        Document[]
  reviews          Review[]
  vaultFiles       VaultFile[]
  auditEvents      AuditEvent[]
  documentTemplates DocumentTemplate[]
  folders          Folder[]
  tags             Tag[]
  organization     Organization?        @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model WorkspaceMembership {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        String    @default("customer")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@index([role])
  @@index([workspaceId, role])
  @@index([role, isActive])
}

model LegalRequest {
  id                   String               @id @default(cuid())
  workspaceId          String
  code                 String?
  title                String
  description          String?
  priority             String?
  matterType           String?
  status               String               @default("draft_intake")
  slaDeadline          DateTime?
  createdById          String
  assignedSpecialistId String?
  assignedReviewerId   String?
  engagementId         String?              // FK to Engagement
  assignedPartnerId    String?              // FK to Partner (direct assignment)
  deletedAt            DateTime?            // Soft delete
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  workspace            Workspace            @relation(fields: [workspaceId], references: [id])
  createdBy            User                 @relation("RequestCreator", fields: [createdById], references: [id])
  assignedSpecialist   User?                @relation("AssignedSpecialist", fields: [assignedSpecialistId], references: [id])
  assignedReviewer     User?                @relation("AssignedReviewer", fields: [assignedReviewerId], references: [id])
  engagement           Engagement?          @relation(fields: [engagementId], references: [id])
  assignedPartner      Partner?              @relation(fields: [assignedPartnerId], references: [id], name: "AssignedPartnerRelation")
  assignments          RequestAssignment[]
  documents            Document[]
  reviews              Review[]
  vaultFiles            VaultFile[]
  files                File[]
  intakeSubmission     IntakeSubmission?
  workflowTransitions  WorkflowTransition[]
  auditEvents          AuditEvent[]
  messages             Message[]

  @@index([workspaceId])
  @@index([createdById])
  @@index([assignedSpecialistId])
  @@index([assignedReviewerId])
  @@index([status])
  @@index([engagementId])
  @@index([assignedPartnerId])
  @@index([deletedAt])
  @@index([workspaceId, status])
  @@index([assignedSpecialistId, status])
}

model MatterType {
  id             String             @id @default(cuid())
  workspaceId    String?
  key            String
  // Multilingual fields
  label_vi       String?            // Primary label
  label_en       String?            // Optional translations
  label_zh       String?
  label_ja       String?
  description_vi String?            // Primary description
  description_en String?
  description_zh String?
  description_ja String?
  // Language-agnostic fields (stay as-is)
  schemaVersion  String
  questionSchema Json
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  workspace           Workspace?          @relation(fields: [workspaceId], references: [id])
  submissions         IntakeSubmission[]
  routingCapabilities RoutingCapability[]

  @@unique([workspaceId, key])
  @@index([workspaceId])
  @@index([isActive])
}

model IntakeSubmission {
  id                String       @id @default(cuid())
  requestId         String       @unique
  workspaceId       String?
  matterTypeKey     String
  schemaVersion     String
  answers           Json
  answerLabels      Json
  submittedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  request           LegalRequest @relation(fields: [requestId], references: [id])
  matterType        MatterType?  @relation(fields: [workspaceId, matterTypeKey], references: [workspaceId, key])

  @@index([workspaceId, matterTypeKey])
  @@index([submittedAt])
}

model RequestAssignment {
  id          String       @id @default(cuid())
  requestId   String
  userId      String
  kind        String       @default("specialist")
  reason      String?
  partnerId   String?      // FK to Partner
  engagementId String?     // FK to Engagement
  createdAt   DateTime     @default(now())
  createdById String
  request     LegalRequest @relation(fields: [requestId], references: [id])
  user        User         @relation("AssignmentUser", fields: [userId], references: [id])
  createdBy   User         @relation("AssignmentCreator", fields: [createdById], references: [id])
  partner     Partner?      @relation(fields: [partnerId], references: [id], name: "AssignmentPartnerRelation")
  engagement  Engagement?  @relation(fields: [engagementId], references: [id])

  @@index([requestId])
  @@index([userId])
  @@index([kind])
  @@index([partnerId])
  @@index([engagementId])
  @@index([userId, kind])
  @@index([requestId, kind])
}

model RoutingCapability {
  id            String     @id @default(cuid())
  workspaceId   String
  userId        String
  matterTypeKey String
  kind          String     @default("specialist")
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  workspace     Workspace  @relation(fields: [workspaceId], references: [id])
  user          User       @relation(fields: [userId], references: [id])
  matterType    MatterType @relation(fields: [workspaceId, matterTypeKey], references: [workspaceId, key])

  @@unique([workspaceId, userId, matterTypeKey, kind])
  @@index([workspaceId, matterTypeKey, kind, isActive])
  @@index([userId])
}

model DocumentVersion {
  id                 String   @id @default(cuid())
  documentId         String
  templateId         String
  templateVersion    Int
  status             String   @default("draft")
  inputSnapshot      Json
  generatedContent   String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  document           Document @relation(fields: [documentId], references: [id])

  @@index([documentId])
  @@index([templateId])
  @@index([status])
}

model WorkflowTransition {
  id          String       @id @default(cuid())
  requestId   String
  fromStatus  String
  toStatus    String
  actorId     String
  reason      String?
  metadata    Json?
  createdAt   DateTime     @default(now())
  request     LegalRequest @relation(fields: [requestId], references: [id])
  actor       User         @relation(fields: [actorId], references: [id])

  @@index([requestId])
  @@index([actorId])
  @@index([fromStatus, toStatus])
}

model Document {
  id          String       @id @default(cuid())
  workspaceId String
  requestId   String
  title       String
  deletedAt   DateTime?   // Soft delete
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace    @relation(fields: [workspaceId], references: [id])
  request     LegalRequest @relation(fields: [requestId], references: [id])
  reviews     Review[]
  documentVersions DocumentVersion[]

  @@index([workspaceId])
  @@index([requestId])
  @@index([deletedAt])
}

model Review {
  id          String       @id @default(cuid())
  workspaceId String
  requestId   String
  documentId  String
  reviewerId  String
  documentVersionId String?
  status      String       @default("in_progress")
  decision    String?
  generalComment String?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace    @relation(fields: [workspaceId], references: [id])
  request     LegalRequest @relation(fields: [requestId], references: [id])
  document    Document     @relation(fields: [documentId], references: [id])
  reviewer    User         @relation(fields: [reviewerId], references: [id])
  checklistAnswers ReviewChecklistAnswer[]

  @@index([workspaceId])
  @@index([requestId])
  @@index([documentId])
  @@index([reviewerId])
  @@index([documentVersionId])
  @@index([status])
}

model ReviewChecklistAnswer {
  id             String   @id @default(cuid())
  reviewId       String
  checklistItemId String
  passed         Boolean  @default(false)
  comment        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  review         Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([reviewId, checklistItemId])
  @@index([reviewId])
}

model DocumentTemplate {
  id                String   @id @default(cuid())
  workspaceId       String
  matterTypeKey     String
  version           Int      @default(1)
  status            String   @default("draft")
  // Multilingual fields
  label_vi         String?  // Primary label
  label_en         String?  // Optional translations
  label_zh         String?
  label_ja         String?
  description_vi   String?  // Primary description
  description_en   String?
  description_zh   String?
  description_ja   String?
  // Language-agnostic fields
  variableSchema    Json           @default("[]")
  content           String
  previousVersionId String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  workspace         Workspace      @relation(fields: [workspaceId], references: [id])
  previousVersion   DocumentTemplate? @relation("TemplateVersion", fields: [previousVersionId], references: [id])
  nextVersions      DocumentTemplate[] @relation("TemplateVersion")

  @@unique([workspaceId, matterTypeKey, version])
  @@index([workspaceId, matterTypeKey])
  @@index([workspaceId, status])
}

model VaultFile {
  id                String       @id @default(cuid())
  requestId         String
  workspaceId       String
  organizationId    String?
  actorId           String
  filename          String?
  storageKey        String?
  fileKind          String?
  source            String?
  documentVersionId String?
  fromStatus        String?
  toStatus          String?
  reason            String?
  size              Int?
  contentType       String?
  deletedAt         DateTime?   // Soft delete
  createdAt         DateTime     @default(now())
  request           LegalRequest @relation(fields: [requestId], references: [id])
  workspace         Workspace    @relation(fields: [workspaceId], references: [id])
  actor             User         @relation(fields: [actorId], references: [id])
  vaultFileFolders  VaultFileFolder[]
  vaultFileTags     VaultFileTag[]

  @@index([requestId])
  @@index([workspaceId])
  @@index([organizationId])
  @@index([actorId])
  @@index([fileKind])
  @@index([documentVersionId])
  @@index([deletedAt])
}

model Folder {
  id              String           @id @default(cuid())
  workspaceId     String
  // Multilingual name
  name_vi         String?          // Primary name
  name_en         String?          // Optional translations
  name_zh         String?
  name_ja         String?
  parentId        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  workspace       Workspace        @relation(fields: [workspaceId], references: [id])
  parent          Folder?          @relation("FolderHierarchy", fields: [parentId], references: [id])
  children        Folder[]         @relation("FolderHierarchy")
  vaultFileFolders VaultFileFolder[]

  @@unique([workspaceId, parentId, name_vi])
  @@index([workspaceId])
  @@index([parentId])
}

model Tag {
  id           String         @id @default(cuid())
  workspaceId  String
  key          String
  // Multilingual label
  label_vi     String?       // Primary label
  label_en     String?       // Optional translations
  label_zh     String?
  label_ja     String?
  createdAt    DateTime       @default(now())
  workspace    Workspace      @relation(fields: [workspaceId], references: [id])
  vaultFileTags VaultFileTag[]

  @@unique([workspaceId, key])
  @@index([workspaceId])
}

model VaultFileFolder {
  vaultFileId  String
  folderId     String
  createdAt    DateTime   @default(now())
  vaultFile    VaultFile  @relation(fields: [vaultFileId], references: [id])
  folder       Folder     @relation(fields: [folderId], references: [id])

  @@id([vaultFileId, folderId])
  @@index([folderId])
}

model VaultFileTag {
  vaultFileId  String
  tagId        String
  createdAt    DateTime   @default(now())
  vaultFile    VaultFile  @relation(fields: [vaultFileId], references: [id])
  tag          Tag        @relation(fields: [tagId], references: [id])

  @@id([vaultFileId, tagId])
  @@index([tagId])
}

model AuditEvent {
  id              String      @id @default(cuid())
  actorId         String?
  workspaceId     String
  organizationId  String?
  action          String
  targetType      String
  targetId        String
  requestId       String?
  correlationId   String?
  metadataSummary String?
  createdAt       DateTime    @default(now())
  actor           User?       @relation(fields: [actorId], references: [id])
  workspace       Workspace   @relation(fields: [workspaceId], references: [id])
  request         LegalRequest? @relation(fields: [requestId], references: [id])

  @@index([actorId])
  @@index([workspaceId])
  @@index([organizationId])
  @@index([requestId])
  @@index([targetType, targetId])
  @@index([correlationId])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// File storage models
// Note: SQLite doesn't support enums, using String fields instead
// FileCategory values: request_upload, generated_document, vault_file, template, ocr_output, audit_export
// FileVisibility values: private, customer_visible, restricted
// FileStatus values: pending, uploaded, processing, ready, failed, deleted
// FileAccessAction values: upload, download, view, delete, share

model File {
  id             String    @id @default(cuid())
  workspaceId    String
  requestId      String?
  storageDriver  String    @default("local")  // "local" or "s3"
  bucket         String?
  objectKey      String
  originalName   String
  mimeType       String
  size           Int
  checksum       String?
  category       String    @default("request_upload")  // FileCategory
  visibility     String    @default("private")  // FileVisibility
  status         String    @default("pending")  // FileStatus
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workspace       Workspace       @relation(fields: [workspaceId], references: [id])
  request         LegalRequest?   @relation(fields: [requestId], references: [id])
  creator         User            @relation("FileCreator", fields: [createdById], references: [id])
  versions        FileVersion[]
  accessLogs      FileAccessLog[]

  @@index([workspaceId])
  @@index([requestId])
  @@index([category])
  @@index([status])
  @@index([createdById])
}

model FileVersion {
  id             String   @id @default(cuid())
  fileId         String
  versionNumber  Int
  storageDriver  String   @default("local")
  bucket         String?
  objectKey      String
  size           Int
  checksum       String?
  createdById    String
  createdAt      DateTime @default(now())

  file           File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  creator        User     @relation("FileVersionCreator", fields: [createdById], references: [id])

  @@index([fileId])
  @@index([createdById])
}

model FileAccessLog {
  id         String   @id @default(cuid())
  fileId     String
  userId     String?
  action     String   // upload, download, view, delete, share
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  file       File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Message {
  id               String    @id @default(cuid())
  workspaceId      String
  organizationId    String?
  legalRequestId   String?
  senderId         String
  recipientId      String
  content          String
  isRead           Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  legalRequest     LegalRequest? @relation(fields: [legalRequestId], references: [id])
  sender           User      @relation("MessageSender", fields: [senderId], references: [id])
  recipient        User      @relation("MessageRecipient", fields: [recipientId], references: [id])

  @@index([workspaceId])
  @@index([organizationId])
  @@index([legalRequestId])
  @@index([senderId])
  @@index([recipientId])
  @@index([isRead])
}
